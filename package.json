{
  "name": "gemmuse",
  "version": "2.6.0",
  "description": "GemMuse desktop and web jewelry AI generator",
  "author": "Ryan 丁",
  "private": true,
  "main": "dist-desktop/main.js",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/prisma-generate-for-build.mjs",
    "build": "next build",
    "postbuild": "node scripts/copy-sharp-native.mjs && node scripts/patch-standalone-chdir.mjs && node scripts/sync-standalone-static.mjs && node scripts/sync-standalone-public.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "desktop:compile": "tsc -p desktop/tsconfig.json",
    "desktop:dev": "tsx desktop/dev.ts",
    "desktop:build": "node desktop/build-release.mjs",
    "desktop:pack": "node desktop/pack-win-dir.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.103.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "idb-keyval": "^6.2.2",
    "jszip": "^3.10.1",
    "next": "16.2.0",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.gemmuse.desktop",
    "productName": "GemMuse 2.6.0",
    "copyright": "Copyright © Ryan 丁",
    "executableName": "GemMuseDesktop",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release-dist"
    },
    "files": [
      ".next/standalone/**/*",
      "dist-desktop/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-desktop/main.js"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": false
    }
  }
}
